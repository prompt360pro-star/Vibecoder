{
  "name": "@vibecode/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod": "eas build --profile production --platform all",
    "type-check": "tsc --noEmit",
    "lint": "expo lint",
    "clean": "rm -rf .expo .turbo node_modules"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "expo-router": "~3.5.23",
    "expo-status-bar": "~1.12.1",
    "expo-haptics": "~13.0.1",
    "expo-image": "~1.12.15",
    "expo-linear-gradient": "~13.0.2",
    "expo-notifications": "~0.28.17",
    "expo-secure-store": "~13.0.2",
    "expo-splash-screen": "~0.27.5",
    "expo-font": "~12.0.10",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-mmkv": "^2.12.2",
    "lottie-react-native": "^6.7.2",
    "@clerk/clerk-expo": "^2.2.14",
    "@tanstack/react-query": "^5.51.24",
    "zustand": "^4.5.5",
    "@vibecode/shared": "workspace:*",
    "expo-web-browser": "~13.0.3",
    "@expo/vector-icons": "^14.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^20.14.0",
    "@types/react": "~18.2.79",
    "typescript": "^5.5.4"
  }
}
